# Server
NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_ANON_KEY=eyJhbGciOi...

# Redis (Bull + cache)
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
USE_AI_SUMMARIES=true
AI_MODEL=claude-sonnet-4-6

# CORS
CORS_ORIGINS=https://vot-ai.vercel.app,http://localhost:3000

# Feature flags
ENABLE_PUBLIC_STATS=true
STATS_MIN_SESSIONS=1000
ELECTORAL_SILENCE=false

# Storage
PROGRAMS_BUCKET=programs

# Admin (para revision de draft positions)
ADMIN_TOKEN=generate-a-long-random-string-here

# Ingestion
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
CLASSIFICATION_MODEL=claude-haiku-4-5-20251001
STANCE_MODEL=claude-sonnet-4-6

# Logs
LOG_LEVEL=info
